# ──────────────────────────────────────────────────────────────────────────────
# SendFile – Apache configuration
# HTTPS is terminated by HAProxy / pfSense upstream; this server receives HTTP.
# ──────────────────────────────────────────────────────────────────────────────

# ── PHP Runtime Limits (required for 2 GB ZIP uploads) ────────────────────────
# php_value/php_flag only work with mod_php. With PHP-FPM (PHP 8.3), set these
# in your PHP-FPM pool config (/etc/php/8.3/fpm/pool.d/www.conf) or php.ini:
#   php_admin_value[upload_max_filesize] = 2048M
#   php_admin_value[post_max_size]       = 2200M
#   php_admin_value[memory_limit]        = 512M
#   php_admin_value[max_execution_time]  = 7200
#   php_admin_value[max_input_time]      = 7200
#   php_admin_flag[display_errors]       = off
#   php_admin_flag[log_errors]           = off
<IfModule mod_php.c>
    php_value upload_max_filesize 2048M
    php_value post_max_size       2200M
    php_value memory_limit        512M
    php_value max_execution_time  7200
    php_value max_input_time      7200
    php_flag  display_errors      Off
    php_flag  log_errors          Off
</IfModule>

# ── Privacy: suppress access log for this vhost (requires AllowOverride All) ──
# Note: per-directory access log suppression requires the CustomLog directive
# to be set in the VirtualHost block in your Apache main config instead.
# Uncomment the line below only if your Apache is built with mod_logio and
# AllowOverride is set to All (some distributions support this):
# CustomLog /dev/null combined

# ── Security headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options  "nosniff"
    Header always set X-Frame-Options         "DENY"
    Header always set X-XSS-Protection        "1; mode=block"
    Header always set Referrer-Policy         "no-referrer"
    Header always set Permissions-Policy      "geolocation=(), camera=(), microphone=()"
    # HSTS is handled by HAProxy upstream; do not set it here.
</IfModule>

# ── Prevent Apache from compressing file download responses ──────────────────
# mod_deflate buffers the entire response for compression before forwarding it.
# For binary ZIP files this would (a) corrupt the data if the browser does not
# decompress it, and (b) exhaust memory / trigger a HAProxy backend timeout on
# large files.  Setting the "no-gzip" and "dont-vary" environment variables
# tells mod_deflate to skip compression for these requests entirely.
<IfModule mod_setenvif.c>
    SetEnvIf Query_String "(^|&)dl=" no-gzip dont-vary
</IfModule>

# ── Block direct access to sensitive files ────────────────────────────────────
<FilesMatch "^\.|\.meta$|\.filename$">
    Require all denied
</FilesMatch>

# ── Block access to the uploads directory (defence-in-depth) ─────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block any request that directly targets a file inside /uploads/
    RewriteRule ^uploads/ - [F,L]
</IfModule>

# ── Disable directory listing ─────────────────────────────────────────────────
Options -Indexes -MultiViews

# ── Character set ─────────────────────────────────────────────────────────────
AddDefaultCharset UTF-8
