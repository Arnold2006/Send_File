# Backend environment variables
# Copy this file to .env and fill in your values.
# The backend loads these automatically when started via PM2 (see ecosystem.config.js).

# ── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on.  Nginx will proxy requests here.
PORT=3001

# Set to "production" when deploying so the backend also serves the React build.
NODE_ENV=production

# ── CORS ─────────────────────────────────────────────────────────────────────
# Replace with your actual public domain.  Use * only in development.
CORS_ORIGIN=https://your-domain.com

# ── Admin endpoint ───────────────────────────────────────────────────────────
# Protect /api/admin/* with a secret key.
# Leave empty to disable the admin endpoint entirely.
ADMIN_API_KEY=change-me-to-a-strong-random-string
